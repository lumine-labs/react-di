{
    "name": "@lumelabs/react-di",
    "version": "0.1.1",
    "description": "Non-reactive dependency injection library for React built on top of tsyringe with immutable module scopes.",
    "license": "MIT",
    "author": "Egor Arkhipov (Lumelabs)",
    "repository": {
        "type": "git",
        "url": "https://github.com/lumine-labs/react-di"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "react",
        "dependency-injection",
        "di",
        "ioc",
        "tsyringe",
        "typescript",
        "module-scope",
        "frontend-architecture"
    ],
    "type": "module",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./types": {
            "types": "./dist/types.d.ts",
            "import": "./dist/types.js",
            "default": "./dist/types.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE.md"
    ],
    "scripts": {
        "clean": "rimraf dist",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "build": "npm run clean && tsc -p tsconfig.build.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "prepack": "npm run build"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0"
    },
    "dependencies": {
        "tsyringe": "^4.0.0"
    },
    "devDependencies": {
        "@lumelabs/eslint-config-react": "^0.1.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@vitest/coverage-v8": "^4.1.0",
        "jsdom": "^29.0.0",
        "prettier": "^3.8.1",
        "reflect-metadata": "^0.2.2",
        "rimraf": "^6.1.3",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitepress": "^1.6.4",
        "vitest": "^4.1.0"
    }
}
