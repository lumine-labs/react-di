{
    "name": "react-di",
    "version": "0.1.1",
    "description": "Non-reactive dependency injection library for React built on top of tsyringe with immutable module scopes.",
    "license": "MIT",
    "author": "Egor Arkhipov (Lumelabs)",
    "repository": {
        "type": "git",
        "url": "https://github.com/lumine-labs/react-di"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "react",
        "dependency-injection",
        "di",
        "ioc",
        "tsyringe",
        "typescript",
        "module-scope",
        "frontend-architecture"
    ],
    "type": "module",
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "default": "./src/index.ts"
        },
        "./types": {
            "types": "./src/types.ts",
            "default": "./src/types.ts"
        }
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "tsyringe": "^4.0.0"
    },
    "devDependencies": {
        "@lumelabs/eslint-config-react": "^0.1.2",
        "prettier": "^3.8.1"
    }
}
